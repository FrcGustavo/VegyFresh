{
  "dependencies": {
    "@nestjs/mapped-types": "*"
  },
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "seed:api": "pnpm --filter scripts/seed-api run seed"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.11.0"
}
